# Adam Gateway Environment Configuration
# Copy this file to .env and fill in your actual values

# ========================================
# Server Configuration
# ========================================
# Server host
ADAM_HOST=0.0.0.0

# Server port
ADAM_PORT=8000

# Number of worker processes (for production)
ADAM_WORKERS=4

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
ADAM_LOG_LEVEL=INFO

# ========================================
# Security Configuration
# ========================================
# Master API key for admin access
ADAM_MASTER_KEY=your-master-key-here

# JWT secret for token generation
ADAM_JWT_SECRET=your-jwt-secret-here

# JWT expiration time (in hours)
ADAM_JWT_EXPIRE_HOURS=24

# ========================================
# Database Configuration
# ========================================
# Database type (sqlite, postgresql, mysql)
ADAM_DB_TYPE=sqlite

# Database URL (for sqlite: sqlite:///./adam.db)
ADAM_DB_URL=sqlite:///./adam.db

# ========================================
# Redis Configuration (Optional)
# ========================================
# Redis URL (for caching and rate limiting)
ADAM_REDIS_URL=redis://localhost:6379/0

# Enable Redis caching
ADAM_ENABLE_CACHE=false

# Cache TTL in seconds
ADAM_CACHE_TTL=3600

# ========================================
# Rate Limiting Configuration
# ========================================
# Enable rate limiting
ADAM_ENABLE_RATE_LIMIT=true

# Requests per minute (global)
ADAM_RATE_LIMIT_RPM=120

# Requests per minute (per user)
ADAM_USER_RATE_LIMIT_RPM=60

# ========================================
# Provider Configuration
# ========================================
# Path to provider configuration directory
ADAM_PROVIDER_CONFIG_DIR=configs/providers

# ========================================
# OpenAI Provider
# ========================================
# OpenAI API key
OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI API base URL (optional, for proxy)
OPENAI_BASE_URL=https://api.openai.com/v1

# ========================================
# Anthropic Provider
# ========================================
# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Anthropic API base URL (optional)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ========================================
# Google Gemini Provider
# ========================================
# Google API key
GOOGLE_API_KEY=your-google-api-key-here

# Google API base URL (optional)
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# ========================================
# Logging Configuration
# ========================================
# Log file path
ADAM_LOG_FILE=logs/adam-gateway.log

# Enable structured JSON logging
ADAM_JSON_LOGGING=false

# ========================================
# MCP Configuration (Optional)
# ========================================
# Enable MCP server
ADAM_ENABLE_MCP=false

# MCP server port
ADAM_MCP_PORT=8001
